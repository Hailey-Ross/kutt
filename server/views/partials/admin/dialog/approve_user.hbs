<div class="content">
  <h2>Approve user?</h2>
  <p>
    Are you sure you want to approve the user &quot;<b>{{email}}</b>&quot;? They will be able to log in.
  </p>
  <div class="buttons">
    <button type="button" hx-on:click="closeDialog()">Cancel</button>
    <button
      type="button"
      class="primary confirm"
      hx-post="/api/users/admin/approve/{id}"
      hx-ext="path-params"
      hx-vals='{"id":"{{id}}"}'
      hx-target="closest .content"
      hx-swap="none"
      hx-indicator="closest .content"
      hx-select-oob="#dialog-error"
    >
      <span class="check">
        {{> icons/check}}
      </span>
      Approve
    </button>
    {{> icons/spinner}}
  </div>
  <div id="dialog-error">
    {{#if error}}
      <p class="error">{{error}}</p>
    {{/if}}
  </div>
</div>
